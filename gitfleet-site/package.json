{
  "name": "gitfleet-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.15.0",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11.15.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "eslint . && astro check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run src",
    "test:integration": "vitest run tests",
    "verify": "pnpm format:check && pnpm lint && pnpm test && pnpm build && pnpm test:integration"
  },
  "dependencies": {
    "@lucide/astro": "^1.25.0",
    "@tailwindcss/vite": "^4.3.3",
    "astro": "^7.1.1",
    "tailwindcss": "^4.3.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "eslint-plugin-astro": "^3.0.1",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
