---
import HeroSection from "../components/HeroSection.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import TerminalPanel from "../components/TerminalPanel.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const description =
  "Gitfleet is a provider-neutral CLI for managing repositories across GitHub and GitLab.";
---

<BaseLayout title="Gitfleet" description={description}>
  <main class="min-h-dvh overflow-x-hidden bg-canvas text-ink">
    <section class="mx-auto flex min-h-dvh w-full max-w-7xl flex-col px-5 py-5 sm:px-8 lg:px-10">
      <SiteHeader />

      <div
        class="grid flex-1 items-center gap-8 py-6 md:grid-cols-[1.06fr_0.94fr] md:py-7 lg:gap-12"
      >
        <HeroSection />
        <TerminalPanel />
      </div>

      <SiteFooter />
    </section>
  </main>

  <script>
    import "../scripts/homepage";
  </script>
</BaseLayout>
